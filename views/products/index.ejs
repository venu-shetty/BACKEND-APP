<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products Admin Page</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <h2>Products Admin Page</h2>
    <a href="/products/add">Add Product</a>

    <div class="products-container">
        <% products.forEach(product => { %>
            <div class="product-box">
                <p><strong>Name:</strong> <%= product.name %></p>
                <p><strong>Description:</strong> <%= product.desc %></p>
                <p><strong>Price:</strong> $<%= product.price %></p>
                <p><strong>Image:</strong> <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="product-image"></p>
                <p>
                    <a href="/products/<%= product._id %>/edit">Edit</a> | 
                    <a href="/products/<%= product._id %>/delete">Delete</a>
                </p>
            </div>
        <% }) %>
    </div>
</body>
</html>