<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Edit Order Form</h2>
    <form action="/orders/<%= order._id %>/save" method="POST">
        <label for="customerName">Customer Name:</label>
        <input type="text" id="customerName" name="customerName" value="<%= order.customerName %>" required><br><br>

        <label for="product">Product:</label>
        <input type="text" id="product" name="product" value="<%= order.product %>" required><br><br>

        <label for="quantity">Quantity:</label>
        <input type="number" id="quantity" name="quantity" value="<%= order.quantity %>" required><br><br>

        <button type="submit">Save Order</button>
    </form>

</body>
</html>